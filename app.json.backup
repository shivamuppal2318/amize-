{
  "expo": {
    "name": "Amize",
    "slug": "shivam",
    "newArchEnabled": true,
    "version": "1.0.1",
    "runtimeVersion": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "com.kentom.amize",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "notification": {
      "icon": "./assets/images/notification-icon.png",
      "color": "#FF4D67"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "jsEngine": "hermes",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera to take photos and record videos",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to access your microphone for recording videos with sound",
        "NSPhotoLibraryUsageDescription": "Allow $(PRODUCT_NAME) to access your photos to save and share media",
        "NSPhotoLibraryAddUsageDescription": "Allow $(PRODUCT_NAME) to save photos and videos to your photo library",
        "NSLocationWhenInUseUsageDescription": "Allow $(PRODUCT_NAME) to access your location to discover nearby creators and content",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.developer.networking.wifi-info": true
      },
      "bundleIdentifier": "com.kentom.amize"
    },
    "android": {
      "package": "com.kentom.amize",
      "jsEngine": "hermes",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow access to photos",
          "savePhotosPermission": "Allow saving photos",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF4D67"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true,
            "extraGradlePlugins": [
              {
                "plugin": "com.google.gms.google-services",
                "apply": false
              }
            ],
            "appGradle": {
              "dependencies": [
                "implementation platform('com.google.firebase:firebase-bom:34.6.0')",
                "implementation 'com.google.firebase:firebase-analytics'"
              ],
              "plugins": [
                "com.google.gms.google-services"
              ]
            }
          }
        }
      ],
      "expo-apple-authentication",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-9338234499986796~9603301111",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "delayAppMeasurementInit": true,
          "optimizeInitialization": true,
          "optimizeAdLoading": true,
          "userTrackingUsageDescription": "Allow $(PRODUCT_NAME) to use tracking to deliver more relevant ads."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": [],
          "enableGooglePay": false
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "supportEmail": "support@amize.com",
      "siteUrl": "https://82.112.238.182:4001",
      "apiUrl": "http://82.112.238.182:4001/api",
      "socketUrl": "ws://82.112.238.182:4001",
      "privacyPolicyUrl": "https://82.112.238.182:4001/privacy",
      "termsOfServiceUrl": "https://82.112.238.182:4001/terms",
      "facebookAppId": "YOUR_FACEBOOK_APP_ID",
      "googleWebClientId": "188596080280-jftm5uhn8q9hk1repn686tbk5urh4b7u.apps.googleusercontent.com",
      "googleAndroidClientId": "188596080280-7e6jt20ikgsfifdlse50ftvo8p3bb5s5.apps.googleusercontent.com",
      "googleIosClientId": "",
      "admobExploreBannerId": "ca-app-pub-9338234499986796/3037045301",
      "admobNearbyBannerId": "ca-app-pub-9338234499986796/3037045301",
      "admobAndroidAppId": "ca-app-pub-9338234499986796~9603301111",
      "admobIosAppId": "",
      "enableLiveStreaming": false,
      "demoMode": false,
      "allowVerificationBypass": true,
      "clerkPublishableKey": "pk_test_aW4tcmFwdG9yLTU0LmNsZXJrLmFjY291bnRzLmRldiQ",
      "eas": {
        "projectId": "d3b1d201-a075-4f9a-811a-73f7c3b6bd2e"
      }
    },
    "owner": "shivammmmmmmmuppal"
  }
}
