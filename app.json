{
  "expo": {
    "name": "Amize",
    "slug": "amize",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["assets/**/*"],

    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "notification": {
      "icon": "./assets/images/notification-icon.png",
      "color": "#FF4D67"
    },

    "ios": {
      "supportsTablet": true,
      "jsEngine": "hermes",
      "newArchEnabled": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera to take photos and record videos",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to access your microphone for recording videos with sound",
        "NSPhotoLibraryUsageDescription": "Allow $(PRODUCT_NAME) to access your photos to save and share media",
        "NSPhotoLibraryAddUsageDescription": "Allow $(PRODUCT_NAME) to save photos and videos to your photo library",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "development",
        "com.apple.developer.networking.wifi-info": true
      },
      "bundleIdentifier": "com.kentom.amize",
      "googleServicesFile": "./GoogleService-Info.plist"
    },

    "android": {
      "package": "com.kentom.amize",
      "jsEngine": "hermes",
      "newArchEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json"
    },

    "plugins": [
      "expo-router",

      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],

      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
          "recordAudioAndroid": true
        }
      ],

      [
        "expo-media-library",
        {
          "photosPermission": "Allow access to photos",
          "savePhotosPermission": "Allow saving photos",
          "isAccessMediaLocationEnabled": true
        }
      ],

      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],

      "expo-font",

      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF4D67"
        }
      ],
      "@react-native-google-signin/google-signin",
      [
        "expo-build-properties",
        {
          "android": {
            "extraGradlePlugins": [
              { "plugin": "com.google.gms.google-services", "apply": false }
            ],
            "appGradle": {
              "dependencies": [
                "implementation platform('com.google.firebase:firebase-bom:34.6.0')",
                "implementation 'com.google.firebase:firebase-analytics'"
              ],
              "plugins": ["com.google.gms.google-services"]
            }
          }
        }
      ],

      "expo-secure-store"
    ],

    "extra": {
      "router": { "origin": false },
      "eas": { "projectId": "3114607c-2f05-4362-ae2e-27adab94dcb0" }
    },

    "owner": "dev-pearl-2024"
  }
}
