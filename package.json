    "release:audit": "node ./scripts/release-audit.cjs",
    "release:audit:android-core": "node ./scripts/release-audit.cjs --platform android --core",
    "release:check": "npm run typecheck && npm run release:audit",
    "release:android:preflight": "npm run typecheck && npm run release:audit:android-core && npm run android:export-check",
    "release:android:qa-preflight": "npm run release:android:preflight",
    "android:export-check": "expo export --platform android --output-dir dist-android-check",
    "test": "jest --watchAll",
    "lint": "expo lint"
  },
  "jest": {
    "preset": "jest-expo"
  },
